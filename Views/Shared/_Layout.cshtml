@{
    var currentPage = ViewData["Title"]?.ToString() ?? "";
}
@inject BabyMonitarr.Backend.Services.IAppVersionProvider AppVersionProvider
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - BabyMonitarr</title>
    <link rel="icon" type="image/svg+xml" href="~/images/icon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#232326" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="apple-touch-icon" href="/images/icon-192.png" />
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
</head>
<body>
    <aside class="sidebar">
        <div class="sidebar-header">
            <img src="~/images/icon.svg" alt="BabyMonitarr" class="sidebar-logo-icon" />
            <span class="sidebar-logo">BabyMonitarr</span>
        </div>
        <nav class="sidebar-nav">
            <a asp-controller="Home" asp-action="Dashboard" class="sidebar-link @(currentPage.Contains("Dashboard") ? "active" : "")">
                <i class="fas fa-th-large"></i>
                <span>Dashboard</span>
            </a>
            <a asp-controller="Home" asp-action="Index" class="sidebar-link @(currentPage.Contains("Room Configuration") ? "active" : "")">
                <i class="fas fa-video"></i>
                <span>Room Configuration</span>
            </a>
            <a asp-controller="Home" asp-action="System" class="sidebar-link @(currentPage.Contains("System") ? "active" : "")">
                <i class="fas fa-cog"></i>
                <span>System</span>
            </a>
            <a asp-controller="ApiKeys" asp-action="Index" class="sidebar-link @(currentPage.Contains("API Keys") ? "active" : "")">
                <i class="fas fa-key"></i>
                <span>API Keys</span>
            </a>
            <a asp-controller="Home" asp-action="About" class="sidebar-link @(currentPage.Contains("About") ? "active" : "")">
                <i class="fas fa-info-circle"></i>
                <span>About</span>
            </a>
        </nav>
        <div class="sidebar-footer">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px;">
                    <span style="display: flex; align-items: center; gap: 6px; font-size: 0.85rem; color: var(--text-secondary);">
                        <i class="fas fa-user-circle"></i> @User.Identity.Name
                    </span>
                    <a href="/auth/logout" style="font-size: 0.8rem; color: var(--text-muted);" title="Sign out">
                        <i class="fas fa-sign-out-alt"></i>
                    </a>
                </div>
            }
            <span>BabyMonitarr v@AppVersionProvider.DisplayVersion</span>
            <span>Made with <i class="fas fa-heart sidebar-heart"></i></span>
        </div>
    </aside>

    <div class="main-wrapper">
        <main class="main-content">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/sw.js').catch(function(err) {
                console.warn('Service worker registration failed:', err);
            });
        }
    </script>
</body>
</html>
